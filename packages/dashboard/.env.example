# Enable live read-only reports data from the backend.
# Review submission remains blocked until real user context exists.
# Use an absolute URL if the backend sends CORS for your dashboard origin.
VITE_BARTOOLS_API_BASE_URL=

# Local-dev fallback when the remote backend does not yet send CORS.
# Set VITE_BARTOOLS_API_BASE_URL=/api and point this proxy target at staging.
# BARTOOLS_API_PROXY_TARGET=
