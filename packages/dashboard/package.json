{
  "name": "@bartools/dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:staging": "sh ./scripts/dev-staging.sh",
    "build": "tsc -b && vite build",
    "build-storybook": "storybook build",
    "lint": "eslint . && bun ./scripts/enforce-code-quality.mjs",
