{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "bun": "1.3.11"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_BARTOOLS_API_URL": "https://bartools-backend-staging-zjausnxoyq-ue.a.run.app"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "staging": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "staging",
      "env": {
        "EXPO_PUBLIC_BARTOOLS_API_URL": "https://bartools-backend-staging-zjausnxoyq-ue.a.run.app"
      }
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      },
      "ios": {
        "ascAppId": "6762476579",
        "ascApiKeyPath": "./AuthKey.p8",
        "ascApiKeyIssuerId": "38efbc62-e5f6-4f50-9adf-d04d8b188130",
        "ascApiKeyId": "BXUN39KMTG"
      }
    }
  }
}
