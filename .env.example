# Copy to .env and fill in values
DATABASE_URL=postgresql://bartools:bartools@localhost:5432/bartools

# used by claude code sdk
CLAUDE_CODE_OAUTH_TOKEN=

# LangSmith (used by @bartools/eval) — https://smith.langchain.com → Settings → API Keys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bartools
# LANGSMITH_WORKSPACE_ID=     # optional, multi-workspace
# LANGSMITH_ENDPOINT=         # optional, self-hosted

# backend prompt resolution
BACKEND_LANGSMITH_PROMPT_NAME=verbena-simple-eval

# GCS uploads (Track B)
GCS_BUCKET=bartools-uploads-staging
GCS_PRESIGNED_PUT_TTL_SECONDS=300
# For local dev only — Cloud Run uses the attached service account:
# Run `gcloud auth application-default login` and ensure your principal has
# roles/storage.objectAdmin on the bucket and roles/iam.serviceAccountTokenCreator
# on the bartools-backend-staging service account.
