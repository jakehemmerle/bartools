# Copy to .env and fill in values
DATABASE_URL=postgresql://bartools:bartools@localhost:5432/bartools

# used by claude code sdk
CLAUDE_CODE_OAUTH_TOKEN=

# LangSmith (used by @bartools/eval) — https://smith.langchain.com → Settings → API Keys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bartools
# LANGSMITH_WORKSPACE_ID=     # optional, multi-workspace
# LANGSMITH_ENDPOINT=         # optional, self-hosted
